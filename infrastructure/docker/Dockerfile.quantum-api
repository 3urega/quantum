# FastAPI + Qiskit (context: repository root)
FROM python:3.11-slim-bookworm

WORKDIR /app

COPY apps/quantum-api/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY apps/quantum-api/app ./app
COPY apps/quantum-api/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENV PYTHONPATH=/app
# Railway (y otros PaaS) inyectan PORT; local/docker suele usar 8000
ENV PORT=8000
EXPOSE 8000

ENTRYPOINT ["/docker-entrypoint.sh"]
