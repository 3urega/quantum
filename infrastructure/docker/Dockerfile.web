# Next.js web service (context: repository root — workspaces)
# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim

WORKDIR /app

# Copy the full monorepo so workspace dependencies (e.g. @quantum-ops/shared-types)
# are available during install and build.
COPY . .

# Install all workspace dependencies from the monorepo root.
RUN npm ci

# Build the Next.js app via the workspace script.
RUN npm run build -w @quantum-ops/web

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

# Verify the homepage returns HTTP 200 before the container is marked healthy.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/', (r) => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))"

CMD npm start -w @quantum-ops/web
