# Next.js web service (context: repository root — workspaces)
# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim

WORKDIR /app

# Copy the full monorepo so workspace dependencies (e.g. @quantum-ops/shared-types)
# are available during install and build.
COPY . .

# Install all workspace dependencies from the monorepo root.
RUN npm ci

# Build the Next.js app via the workspace script.
RUN npm run build -w @quantum-ops/web

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

# Local Docker: probe /. Use the same port the app listens on (default 3000; Railway overwrites at runtime).
HEALTHCHECK --interval=30s --timeout=10s --start-period=50s --retries=3 \
  CMD sh -c 'node -e "const p=process.env.PORT||3000; const h=require(\"http\");h.get({hostname:\"127.0.0.1\",port:Number(p),path:\"/\"},(r)=>process.exit(r.statusCode===200?0:1)).on(\"error\",()=>process.exit(1));"'

# Do NOT set PORT=3000 here. Railway (and other hosts) set PORT; forcing 3000 would make the app
# listen on the wrong port and fail platform healthchecks with service unavailable.
CMD ["npm", "start", "-w", "@quantum-ops/web"]
