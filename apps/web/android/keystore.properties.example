# Copia a keystore.properties (no se sube a git) y rellena tras crear el keystore, p. ej.:
#   keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore -alias quantum -keyalg RSA -keysize 2048 -validity 10000
#
# Rutas de storeFile son relativas a la carpeta android/

storeFile=release.keystore
storePassword=cambiar
keyAlias=quantum
keyPassword=cambiar
