    "@react-three/fiber": "^9.6.0",
    "@types/mdx": "^2.0.13",
    "katex": "^0.16.44",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-katex": "^7.0.1",
